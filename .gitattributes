# Auto detect text files and normalize line endings
* text=auto

# Shell scripts must use LF (Unix line endings)
*.sh text eol=lf

# Batch scripts use CRLF (Windows line endings)
*.bat text eol=crlf
*.cmd text eol=crlf

# Docker files
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Keep these as LF
.gitattributes text eol=lf
.gitignore text eol=lf
.env* text eol=lf

# Source files should always be LF
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.md text eol=lf
