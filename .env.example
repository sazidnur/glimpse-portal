# Environment Configuration for Glimpse Portal
# Copy this file to .env and fill in your values

# ===========================================
# Django Settings
# ===========================================
DEBUG=False
TZ=Europe/Helsinki
SECRET_KEY=generate-a-strong-secret-key-here
ALLOWED_HOSTS=glimpseapp.net
PORTAL_URL_PREFIX=portal
CSRF_TRUSTED_ORIGINS=https://glimpseapp.net
CORS_ALLOWED_ORIGINS=https://glimpseapp.net

# ===========================================
# Traefik / Domain
# ===========================================
SITE_DOMAIN=glimpseapp.net

# ===========================================
# Django Database (PostgreSQL)
# Used by Django internals and app/business models
# ===========================================
DJANGO_DB_NAME=glimpse_portal
DJANGO_DB_USER=postgres
DJANGO_DB_PASSWORD=change-this-strong-password
DJANGO_DB_HOST=db
DJANGO_DB_PORT=5432

# ===========================================
# REST API Security (WordPress Integration)
# ===========================================
# IP addresses allowed to access the API (comma-separated)
# Get your WordPress server's IP address
# Set to * for development only (NOT for production!)
ALLOWED_API_IPS=123.456.789.0

# Shared secret for HMAC signature verification
# CRITICAL: Generate a strong secret and share with WordPress
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SHARED_SECRET=your-64-character-hex-secret-here

# Rate limit: requests per minute per IP
API_RATE_LIMIT=60
YOUTUBE_API_KEY=your-youtube-api-key-here
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_ANALYTICS_TOKEN=your-cloudflare-analytics-token
ORIGIN_PATH_SECRET=your-origin-path-secret-here(app secret?)

# ===========================================
# OpenAI API (model settings are per-pipeline via Pipeline Config UI)
# ===========================================
OPENAI_API_KEY=your-openai-api-key

# Celery (defaults to REDIS_URL if omitted)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
